{
  "cli": {
    "version": ">= 13.5.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_PRISMBOT_API_BASE": "https://wild-regarding-harper-technical.trycloudflare.com",
        "EXPO_PUBLIC_PRISMBOT_FAMILY_API_BASE": "https://wild-regarding-harper-technical.trycloudflare.com",
        "EXPO_PUBLIC_PRISMBOT_SESSION_KEY": "agent:main:mobile:beta"
      }
    },
    "production": {
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_PRISMBOT_API_BASE": "https://YOUR-BRIDGE-DOMAIN",
        "EXPO_PUBLIC_PRISMBOT_FAMILY_API_BASE": "https://YOUR-FAMILY-DOMAIN",
        "EXPO_PUBLIC_PRISMBOT_SESSION_KEY": "agent:main:mobile:prod"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "",
        "appleTeamId": ""
      }
    }
  }
}
