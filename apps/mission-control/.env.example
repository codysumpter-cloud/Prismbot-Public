# Mission Control deployment settings
# Copy to `.env` and fill in values for your environment.

# Listener settings
HOST=0.0.0.0
PORT=8790

# Optional API auth token for Mission Control.
# - Used for write endpoints (/api/tasks*).
# - Also used for read endpoints when REQUIRE_TOKEN_FOR_READ=true.
# Leave blank to disable write auth (not recommended outside local/VPN-only use).
MISSION_CONTROL_TOKEN=

# Optional stricter auth mode for GET /api/* read endpoints.
# false (default): reads remain permissive for local development.
# true: every read endpoint requires Authorization: Bearer <MISSION_CONTROL_TOKEN>.
REQUIRE_TOKEN_FOR_READ=false

# Bring-your-own OpenClaw gateway settings for future/proxy integrations.
# Example: https://openclaw.yourdomain.com
OPENCLAW_GATEWAY_URL=
# Generate a unique token from your own OpenClaw instance. Never reuse shared tokens.
OPENCLAW_GATEWAY_TOKEN=
