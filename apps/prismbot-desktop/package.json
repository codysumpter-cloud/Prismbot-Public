{
  "name": "prismbot-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "PrismBot Desktop shell with contained local services",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist:linux": "electron-builder --linux AppImage deb",
    "dist:win": "electron-builder --win nsis portable",
    "dist:mac": "electron-builder --mac dmg",
    "postinstall": "echo 'ready'"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.prismtek.prismbot.desktop",
    "productName": "PrismBot Desktop",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
