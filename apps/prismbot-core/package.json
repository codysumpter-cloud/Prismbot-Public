{
  "name": "prismbot-core",
  "version": "0.1.0",
  "private": true,
  "description": "Unified PrismBot core app",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "check": "node --check src/server.js && node --check src/omni/config.js && node --check src/omni/adapters.js && node --check src/omni/router.js && node --check src/omni/execution.js",
    "smoke:omni": "node scripts/omni-smoke.js",
    "smoke:asset-urls": "node scripts/public-asset-url-smoke.js",
    "test:omni:conformance": "node scripts/omni-provider-conformance.js",
    "smoke:omni:routing": "bash scripts/omni-text-routing-smoke.sh", 
    "smoke:omni:live": "bash scripts/omni-live-matrix.sh", 
    "smoke:omni:pixel": "bash scripts/omni-pixel-zoomquilt-smoke.sh",
    "verify:providers:live": "node scripts/omni-provider-live-verify.js",
    "phase2:dataset": "python3 scripts/omni_phase2_build_dataset.py --in training/phase2/raw.csv --out training/phase2/omni_sft.jsonl",
    "phase2:train": "python3 scripts/omni_phase2_train_local.py --dataset training/phase2/omni_sft.jsonl --target-model omni-core:phase2",
    "phase2:eval": "python3 scripts/omni_phase2_eval.py",
    "phase3:dataset": "python3 scripts/omni_phase3_build_dataset.py --base training/phase2/omni_sft.jsonl --feedback training/phase3/feedback.jsonl --runs data/omni-runs.json --out training/phase3/omni_sft_phase3.jsonl",
    "phase3:train": "bash scripts/omni_phase3_train_local.sh",
    "phase3:promote": "bash scripts/omni_phase3_promote.sh",
    "phaseA:bootstrap": "node migrations/001-bootstrap-core.js",
    "phaseA:import:kidchat": "node migrations/002-import-kid-chat.js",
    "phaseA:import:mission": "node migrations/003-import-mission-control.js"
  }
}
