# PrismBot Core runtime env
PORT=8799
CORE_SESSION_COOKIE=pb_core_session
CORE_COOKIE_SECURE=false

# Owner mapping (customize)
CORE_OWNER_USER_IDS=u_admin
CORE_OWNER_USERNAMES=prismtek

# Billing / policy defaults
CORE_ALLOW_SHARED_KEY=true
CORE_FREE_DAILY_REQUEST_LIMIT=50
CORE_FREE_DAILY_TOKEN_LIMIT=100000
CORE_GLOBAL_DAILY_REQUEST_LIMIT=2000
CORE_GLOBAL_DAILY_TOKEN_LIMIT=3000000

# Studio / local image backend integration
CORE_STUDIO_IMAGE_BACKEND=auto
CORE_STUDIO_LOCAL_IMAGE_URL=http://127.0.0.1:7860/sdapi/v1/txt2img
CORE_STUDIO_LOCAL_EDIT_URL=http://127.0.0.1:7860/sdapi/v1/img2img
CORE_STUDIO_LOCAL_TRANSCRIBE_URL=http://127.0.0.1:7860/audio/transcribe

# Public asset URL shaping (end-user safe URLs)
# Leave base URL blank to keep relative /studio-output/... URLs in publicUrl fields.
CORE_PUBLIC_ASSET_BASE_URL=
# public (default) | private (adds signature placeholder query params)
CORE_PUBLIC_ASSET_MODE=public
# Optional signing secret used for placeholder signature hash when mode=private
CORE_PUBLIC_ASSET_SIGNING_SECRET=

# Queue + retries
CORE_STUDIO_IMAGE_QUEUE_CONCURRENCY=1
CORE_STUDIO_IMAGE_RETRY_MAX=1
CORE_STUDIO_IMAGE_RETRY_DELAY_MS=1500
CORE_OMNI_QUEUE_CONCURRENCY=1

# Omni sovereignty defaults (local-only)
OMNI_ROUTING_STRATEGY=local-first
OMNI_OPENAI_ENABLED=false
OMNI_ANTHROPIC_ENABLED=false
OMNI_GOOGLE_ENABLED=false
OMNI_XAI_ENABLED=false
OMNI_OLLAMA_ENABLED=false
OMNI_LOCAL_ENABLED=true
